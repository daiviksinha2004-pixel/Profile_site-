# Copy to .env and fill in. NEVER commit .env.

# --- Chat LLM: OpenAI-compatible provider fallback chain (tried in order) ---
# Each entry: {name, base_url, api_key, model}. Works with Groq / Gemini (OpenAI shim) / OpenRouter / OpenAI.
AI_PROVIDERS=[{"name":"groq-8b","base_url":"https://api.groq.com/openai/v1","api_key":"gsk_xxx","model":"llama-3.1-8b-instant"}]

# Fallback single provider if AI_PROVIDERS is empty/invalid.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
CHAT_MODEL=llama-3.1-8b-instant   # display label for /health
MAX_OUTPUT_TOKENS=1024

# --- Embeddings: OpenAI-compatible (Gemini) ---
AI_API_KEY=AIza_or_gemini_key_xxxxxxxx
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EMBEDDING_MODEL=gemini-embedding-001

# --- Vector store ---
VECTOR_DB=chroma                 # chroma | qdrant | pinecone
CHROMA_PATH=./.chroma
COLLECTION_NAME=portfolio

# --- RAG behaviour ---
KNOWLEDGE_DIR=./data/knowledge
TOP_K=6                          # how many chunks to retrieve per question

# --- Identity (used in the bot's system prompt) ---
OWNER_NAME=Daivik Sinha

# --- CORS (comma-separated origins allowed to call the API) ---
# Add every origin you load the frontend from (localhost AND your LAN/WSL IP).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
